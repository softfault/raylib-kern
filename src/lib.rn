}

/// Draw spline: Linear, minimum 2 points
pub fn draw_spline_linear(points: &mut Vector2, point_count: i32, thick: f32, color: Color) void {
    raw.DrawSplineLinear(points, point_count, thick, color);
}

/// Draw spline: B-Spline, minimum 4 points
pub fn draw_spline_basis(points: &mut Vector2, point_count: i32, thick: f32, color: Color) void {
