impl Color {
    /// Creates a `Color` from red, green, blue, and alpha channels.
    pub const fn rgba(r: u8, g: u8, b: u8, a: u8) Color {
        return .{ r: r, g: g, b: b, a: a };
    }
}

impl Vector2 {
    /// Creates a `Vector2` from x and y coordinates.
    pub const fn xy(x: f32, y: f32) Vector2 {
        return .{ x: x, y: y };
    }
}

impl Vector3 {
    /// Creates a `Vector3` from x, y, and z coordinates.
    pub const fn xyz(x: f32, y: f32, z: f32) Vector3 {
        return .{ x: x, y: y, z: z };
    }
}

impl Rectangle {
    /// Creates a `Rectangle` from position and size.
    pub const fn xywh(x: f32, y: f32, width: f32, height: f32) Rectangle {
        return .{ x: x, y: y, width: width, height: height };
    }
}

/// Creates a `Color` from red, green, blue, and alpha channels.
pub const fn color(r: u8, g: u8, b: u8, a: u8) Color {
    return .{ r: r, g: g, b: b, a: a };
}

/// Creates a `Vector2` from x and y coordinates.
pub const fn vector2(x: f32, y: f32) Vector2 {
    return .{ x: x, y: y };
}

/// Creates a `Vector3` from x, y, and z coordinates.
pub const fn vector3(x: f32, y: f32, z: f32) Vector3 {
    return .{ x: x, y: y, z: z };
}

/// Creates a `Rectangle` from position and size.
pub const fn rectangle(x: f32, y: f32, width: f32, height: f32) Rectangle {
    return .{ x: x, y: y, width: width, height: height };
}

/// Initialize window and OpenGL context
pub fn init_window(width: i32, height: i32, title: &[u8]) void {
    raw.InitWindow(width, height, z_ptr(title));
}

/// Close window and unload OpenGL context
pub fn close_window() void {
    raw.CloseWindow();
}

/// Check if application should close (KEY_ESCAPE pressed or windows close icon clicked)
pub fn window_should_close() bool {
    return raw.WindowShouldClose();
}

/// Check if window has been initialized successfully
pub fn is_window_ready() bool {
    return raw.IsWindowReady();
}

/// Check if window is currently fullscreen
pub fn is_window_fullscreen() bool {
    return raw.IsWindowFullscreen();
}

/// Check if window is currently hidden
pub fn is_window_hidden() bool {
    return raw.IsWindowHidden();
}

/// Check if window is currently minimized
pub fn is_window_minimized() bool {
    return raw.IsWindowMinimized();
}

/// Check if window is currently maximized
pub fn is_window_maximized() bool {
    return raw.IsWindowMaximized();
}

/// Check if window is currently focused
pub fn is_window_focused() bool {
    return raw.IsWindowFocused();
}

/// Check if window has been resized last frame
pub fn is_window_resized() bool {
    return raw.IsWindowResized();
}

/// Check if one specific window flag is enabled
pub fn is_window_state(flag: u32) bool {
    return raw.IsWindowState(flag);
}

/// Set window configuration state using flags
pub fn set_window_state(flags: u32) void {
    raw.SetWindowState(flags);
}

/// Clear window configuration state flags
pub fn clear_window_state(flags: u32) void {
    raw.ClearWindowState(flags);
}

/// Toggle window state: fullscreen/windowed, resizes monitor to match window resolution
pub fn toggle_fullscreen() void {
    raw.ToggleFullscreen();
}

/// Toggle window state: borderless windowed, resizes window to match monitor resolution
pub fn toggle_borderless_windowed() void {
    raw.ToggleBorderlessWindowed();
}

/// Set window state: maximized, if resizable
pub fn maximize_window() void {
    raw.MaximizeWindow();
}

/// Set window state: minimized, if resizable
pub fn minimize_window() void {
    raw.MinimizeWindow();
}

/// Restore window from being minimized/maximized
pub fn restore_window() void {
    raw.RestoreWindow();
}

/// Set icon for window (single image, RGBA 32bit)
pub fn set_window_icon(image: Image) void {
    raw.SetWindowIcon(image);
}

/// Set icon for window (multiple images, RGBA 32bit)
pub fn set_window_icons(images: &mut Image, count: i32) void {
    raw.SetWindowIcons(images, count);
}

/// Set title for window
pub fn set_window_title(title: &[u8]) void {
    raw.SetWindowTitle(z_ptr(title));
}

/// Set window position on screen
pub fn set_window_position(x: i32, y: i32) void {
    raw.SetWindowPosition(x, y);
}

/// Set monitor for the current window
pub fn set_window_monitor(monitor: i32) void {
    raw.SetWindowMonitor(monitor);
}

/// Set window minimum dimensions (for FLAG_WINDOW_RESIZABLE)
pub fn set_window_min_size(width: i32, height: i32) void {
    raw.SetWindowMinSize(width, height);
}

/// Set window maximum dimensions (for FLAG_WINDOW_RESIZABLE)
pub fn set_window_max_size(width: i32, height: i32) void {
    raw.SetWindowMaxSize(width, height);
}

/// Set window dimensions
pub fn set_window_size(width: i32, height: i32) void {
    raw.SetWindowSize(width, height);
}

/// Set window opacity [0.0f..1.0f]
pub fn set_window_opacity(opacity: f32) void {
    raw.SetWindowOpacity(opacity);
}

/// Set window focused
pub fn set_window_focused() void {
    raw.SetWindowFocused();
}

/// Get native window handle
pub fn get_window_handle() &mut void {
    return raw.GetWindowHandle();
}

/// Get current screen width
pub fn get_screen_width() i32 {
    return raw.GetScreenWidth();
}

/// Get current screen height
pub fn get_screen_height() i32 {
    return raw.GetScreenHeight();
}

/// Get current render width (it considers HiDPI)
pub fn get_render_width() i32 {
    return raw.GetRenderWidth();
}

/// Get current render height (it considers HiDPI)
pub fn get_render_height() i32 {
    return raw.GetRenderHeight();
}

/// Get number of connected monitors
pub fn get_monitor_count() i32 {
    return raw.GetMonitorCount();
}

/// Get current monitor where window is placed
pub fn get_current_monitor() i32 {
    return raw.GetCurrentMonitor();
}

/// Get specified monitor position
pub fn get_monitor_position(monitor: i32) Vector2 {
    return raw.GetMonitorPosition(monitor);
}

/// Get specified monitor width (current video mode used by monitor)
pub fn get_monitor_width(monitor: i32) i32 {
    return raw.GetMonitorWidth(monitor);
}

/// Get specified monitor height (current video mode used by monitor)
pub fn get_monitor_height(monitor: i32) i32 {
    return raw.GetMonitorHeight(monitor);
}

/// Get specified monitor physical width in millimetres
pub fn get_monitor_physical_width(monitor: i32) i32 {
    return raw.GetMonitorPhysicalWidth(monitor);
}

/// Get specified monitor physical height in millimetres
pub fn get_monitor_physical_height(monitor: i32) i32 {
    return raw.GetMonitorPhysicalHeight(monitor);
}

/// Get specified monitor refresh rate
pub fn get_monitor_refresh_rate(monitor: i32) i32 {
    return raw.GetMonitorRefreshRate(monitor);
}

/// Get window position XY on monitor
pub fn get_window_position() Vector2 {
    return raw.GetWindowPosition();
}

/// Get window scale DPI factor
pub fn get_window_scale_dpi() Vector2 {
    return raw.GetWindowScaleDPI();
}

/// Get the human-readable, UTF-8 encoded name of the specified monitor
pub fn get_monitor_name(monitor: i32) &u8 {
    return raw.GetMonitorName(monitor);
}

/// Set clipboard text content
pub fn set_clipboard_text(text: &[u8]) void {
    raw.SetClipboardText(z_ptr(text));
}

/// Get clipboard text content
pub fn get_clipboard_text() &u8 {
    return raw.GetClipboardText();
}

/// Get clipboard image content
pub fn get_clipboard_image() Image {
    return raw.GetClipboardImage();
}

/// Enable waiting for events on EndDrawing(), no automatic event polling
pub fn enable_event_waiting() void {
    raw.EnableEventWaiting();
}

/// Disable waiting for events on EndDrawing(), automatic events polling
pub fn disable_event_waiting() void {
    raw.DisableEventWaiting();
}

/// Shows cursor
pub fn show_cursor() void {
    raw.ShowCursor();
}

/// Hides cursor
pub fn hide_cursor() void {
    raw.HideCursor();
}

/// Check if cursor is not visible
pub fn is_cursor_hidden() bool {
    return raw.IsCursorHidden();
}

/// Enables cursor (unlock cursor)
pub fn enable_cursor() void {
    raw.EnableCursor();
}

/// Disables cursor (lock cursor)
pub fn disable_cursor() void {
    raw.DisableCursor();
}

/// Check if cursor is on the screen
pub fn is_cursor_on_screen() bool {
    return raw.IsCursorOnScreen();
}

/// Set background color (framebuffer clear color)
pub fn clear_background(color: Color) void {
    raw.ClearBackground(color);
}

/// Setup canvas (framebuffer) to start drawing
pub fn begin_drawing() void {
    raw.BeginDrawing();
}

/// End canvas drawing and swap buffers (double buffering)
pub fn end_drawing() void {
    raw.EndDrawing();
}

/// Begin 2D mode with custom camera (2D)
pub fn begin_mode_2d(camera: Camera2D) void {
    raw.BeginMode2D(camera);
}

/// Ends 2D mode with custom camera
pub fn end_mode_2d() void {
    raw.EndMode2D();
}

/// Begin 3D mode with custom camera (3D)
pub fn begin_mode_3d(camera: Camera3D) void {
    raw.BeginMode3D(camera);
}

/// Ends 3D mode and returns to default 2D orthographic mode
pub fn end_mode_3d() void {
    raw.EndMode3D();
}

/// Begin drawing to render texture
pub fn begin_texture_mode(target: RenderTexture2D) void {
    raw.BeginTextureMode(target);
}

/// Ends drawing to render texture
pub fn end_texture_mode() void {
    raw.EndTextureMode();
}

/// Begin custom shader drawing
pub fn begin_shader_mode(shader: Shader) void {
    raw.BeginShaderMode(shader);
}

/// End custom shader drawing (use default shader)
pub fn end_shader_mode() void {
    raw.EndShaderMode();
}

/// Begin blending mode (alpha, additive, multiplied, subtract, custom)
pub fn begin_blend_mode(mode: BlendMode) void {
    raw.BeginBlendMode(mode);
}

/// End blending mode (reset to default: alpha blending)
pub fn end_blend_mode() void {
    raw.EndBlendMode();
}

/// Begin scissor mode (define screen area for following drawing)
pub fn begin_scissor_mode(x: i32, y: i32, width: i32, height: i32) void {
    raw.BeginScissorMode(x, y, width, height);
}

/// End scissor mode
pub fn end_scissor_mode() void {
    raw.EndScissorMode();
}

/// Begin stereo rendering (requires VR simulator)
pub fn begin_vr_stereo_mode(config: VrStereoConfig) void {
    raw.BeginVrStereoMode(config);
}

/// End stereo rendering (requires VR simulator)
pub fn end_vr_stereo_mode() void {
    raw.EndVrStereoMode();
}

/// Load VR stereo config for VR simulator device parameters
pub fn load_vr_stereo_config(device: VrDeviceInfo) VrStereoConfig {
    return raw.LoadVrStereoConfig(device);
}

/// Unload VR stereo config
pub fn unload_vr_stereo_config(config: VrStereoConfig) void {
    raw.UnloadVrStereoConfig(config);
}

/// Load shader from files and bind default locations
pub fn load_shader(vs_file_name: &[u8], fs_file_name: &[u8]) Shader {
    return raw.LoadShader(z_ptr(vs_file_name), z_ptr(fs_file_name));
}

/// Load shader from code strings and bind default locations
pub fn load_shader_from_memory(vs_code: &[u8], fs_code: &[u8]) Shader {
    return raw.LoadShaderFromMemory(z_ptr(vs_code), z_ptr(fs_code));
}

/// Check if a shader is valid (loaded on GPU)
pub fn is_shader_valid(shader: Shader) bool {
    return raw.IsShaderValid(shader);
}

/// Get shader uniform location
pub fn get_shader_location(shader: Shader, uniform_name: &[u8]) i32 {
    return raw.GetShaderLocation(shader, z_ptr(uniform_name));
}

/// Get shader attribute location
pub fn get_shader_location_attrib(shader: Shader, attrib_name: &[u8]) i32 {
    return raw.GetShaderLocationAttrib(shader, z_ptr(attrib_name));
}

/// Set shader uniform value
pub fn set_shader_value(shader: Shader, loc_index: i32, value: &mut void, uniform_type: ShaderUniformDataType) void {
    raw.SetShaderValue(shader, loc_index, value, uniform_type);
}

/// Set shader uniform value vector
pub fn set_shader_value_v(shader: Shader, loc_index: i32, value: &mut void, uniform_type: ShaderUniformDataType, count: i32) void {
    raw.SetShaderValueV(shader, loc_index, value, uniform_type, count);
}

/// Set shader uniform value (matrix 4x4)
pub fn set_shader_value_matrix(shader: Shader, loc_index: i32, mat: Matrix) void {
    raw.SetShaderValueMatrix(shader, loc_index, mat);
}

/// Set shader uniform value and bind the texture (sampler2d)
pub fn set_shader_value_texture(shader: Shader, loc_index: i32, texture: Texture2D) void {
    raw.SetShaderValueTexture(shader, loc_index, texture);
}

/// Unload shader from GPU memory (VRAM)
pub fn unload_shader(shader: Shader) void {
    raw.UnloadShader(shader);
}

/// Get a ray trace from screen position (i.e mouse)
pub fn get_screen_to_world_ray(position: Vector2, camera: Camera) Ray {
    return raw.GetScreenToWorldRay(position, camera);
}

/// Get a ray trace from screen position (i.e mouse) in a viewport
pub fn get_screen_to_world_ray_ex(position: Vector2, camera: Camera, width: i32, height: i32) Ray {
    return raw.GetScreenToWorldRayEx(position, camera, width, height);
}

/// Get the screen space position for a 3d world space position
pub fn get_world_to_screen(position: Vector3, camera: Camera) Vector2 {
    return raw.GetWorldToScreen(position, camera);
}

/// Get size position for a 3d world space position
pub fn get_world_to_screen_ex(position: Vector3, camera: Camera, width: i32, height: i32) Vector2 {
    return raw.GetWorldToScreenEx(position, camera, width, height);
}

/// Get the screen space position for a 2d camera world space position
pub fn get_world_to_screen_2d(position: Vector2, camera: Camera2D) Vector2 {
    return raw.GetWorldToScreen2D(position, camera);
}

/// Get the world space position for a 2d camera screen space position
pub fn get_screen_to_world_2d(position: Vector2, camera: Camera2D) Vector2 {
    return raw.GetScreenToWorld2D(position, camera);
}

/// Get camera transform matrix (view matrix)
pub fn get_camera_matrix(camera: Camera) Matrix {
    return raw.GetCameraMatrix(camera);
}

/// Get camera 2d transform matrix
pub fn get_camera_matrix_2d(camera: Camera2D) Matrix {
    return raw.GetCameraMatrix2D(camera);
}

/// Set target FPS (maximum)
pub fn set_target_fps(fps: i32) void {
    raw.SetTargetFPS(fps);
}

/// Get time in seconds for last frame drawn (delta time)
pub fn get_frame_time() f32 {
    return raw.GetFrameTime();
}

/// Get elapsed time in seconds since InitWindow()
pub fn get_time() f64 {
    return raw.GetTime();
}

/// Get current FPS
pub fn get_fps() i32 {
    return raw.GetFPS();
}

/// Swap back buffer with front buffer (screen drawing)
pub fn swap_screen_buffer() void {
    raw.SwapScreenBuffer();
}

/// Register all input events
pub fn poll_input_events() void {
    raw.PollInputEvents();
}

/// Wait for some time (halt program execution)
pub fn wait_time(seconds: f64) void {
    raw.WaitTime(seconds);
}

/// Set the seed for the random number generator
pub fn set_random_seed(seed: u32) void {
    raw.SetRandomSeed(seed);
}

/// Get a random value between min and max (both included)
pub fn get_random_value(min: i32, max: i32) i32 {
    return raw.GetRandomValue(min, max);
}

/// Load random values sequence, no values repeated
pub fn load_random_sequence(count: u32, min: i32, max: i32) &mut i32 {
    return raw.LoadRandomSequence(count, min, max);
}

/// Unload random values sequence
pub fn unload_random_sequence(sequence: &mut i32) void {
    raw.UnloadRandomSequence(sequence);
}

/// Takes a screenshot of current screen (filename extension defines format)
pub fn take_screenshot(file_name: &[u8]) void {
    raw.TakeScreenshot(z_ptr(file_name));
}

/// Setup init configuration flags (view FLAGS)
pub fn set_config_flags(flags: u32) void {
    raw.SetConfigFlags(flags);
}

/// Open URL with default system browser (if available)
pub fn open_url(url: &[u8]) void {
    raw.OpenURL(z_ptr(url));
}

/// Set the current threshold (minimum) log level
pub fn set_trace_log_level(log_level: TraceLogLevel) void {
    raw.SetTraceLogLevel(log_level);
}

/// Internal memory allocator
pub fn mem_alloc(size: u32) &mut void {
    return raw.MemAlloc(size);
}

/// Internal memory reallocator
pub fn mem_realloc(ptr: &mut void, size: u32) &mut void {
    return raw.MemRealloc(ptr, size);
}

/// Internal memory free
pub fn mem_free(ptr: &mut void) void {
    raw.MemFree(ptr);
}

/// Load file data as byte array (read)
pub fn load_file_data(file_name: &[u8], data_size: &mut i32) &u8 {
    return raw.LoadFileData(z_ptr(file_name), data_size);
}

/// Unload file data allocated by LoadFileData()
pub fn unload_file_data(data: &u8) void {
    raw.UnloadFileData(data);
}

/// Save data to file from byte array (write), returns true on success
pub fn save_file_data(file_name: &[u8], data: &mut void, data_size: i32) bool {
    return raw.SaveFileData(z_ptr(file_name), data, data_size);
}

/// Export data to code (.h), returns true on success
pub fn export_data_as_code(data: &u8, data_size: i32, file_name: &[u8]) bool {
    return raw.ExportDataAsCode(data, data_size, z_ptr(file_name));
}

/// Load text data from file (read), returns a '\0' terminated string
pub fn load_file_text(file_name: &[u8]) &u8 {
    return raw.LoadFileText(z_ptr(file_name));
}

/// Unload file text data allocated by LoadFileText()
pub fn unload_file_text(text: &[u8]) void {
    raw.UnloadFileText(z_ptr(text));
}

/// Save text data to file (write), string must be '\0' terminated, returns true on success
pub fn save_file_text(file_name: &[u8], text: &[u8]) bool {
    return raw.SaveFileText(z_ptr(file_name), z_ptr(text));
}

/// Rename file (if exists)
pub fn file_rename(file_name: &[u8], file_rename: &[u8]) i32 {
    return raw.FileRename(z_ptr(file_name), z_ptr(file_rename));
}

/// Remove file (if exists)
pub fn file_remove(file_name: &[u8]) i32 {
    return raw.FileRemove(z_ptr(file_name));
}

/// Copy file from one path to another, dstPath created if it doesn't exist
pub fn file_copy(src_path: &[u8], dst_path: &[u8]) i32 {
    return raw.FileCopy(z_ptr(src_path), z_ptr(dst_path));
}

/// Move file from one directory to another, dstPath created if it doesn't exist
pub fn file_move(src_path: &[u8], dst_path: &[u8]) i32 {
    return raw.FileMove(z_ptr(src_path), z_ptr(dst_path));
}

/// Replace text in an existing file
pub fn file_text_replace(file_name: &[u8], search: &[u8], replacement: &[u8]) i32 {
    return raw.FileTextReplace(z_ptr(file_name), z_ptr(search), z_ptr(replacement));
}

/// Find text in existing file
pub fn file_text_find_index(file_name: &[u8], search: &[u8]) i32 {
    return raw.FileTextFindIndex(z_ptr(file_name), z_ptr(search));
}

/// Check if file exists
pub fn file_exists(file_name: &[u8]) bool {
    return raw.FileExists(z_ptr(file_name));
}

/// Check if a directory path exists
pub fn directory_exists(dir_path: &[u8]) bool {
    return raw.DirectoryExists(z_ptr(dir_path));
}

/// Check file extension (recommended include point: .png, .wav)
pub fn is_file_extension(file_name: &[u8], ext: &[u8]) bool {
    return raw.IsFileExtension(z_ptr(file_name), z_ptr(ext));
}

/// Get file length in bytes (NOTE: GetFileSize() conflicts with windows.h)
pub fn get_file_length(file_name: &[u8]) i32 {
    return raw.GetFileLength(z_ptr(file_name));
}

/// Get file modification time (last write time)
pub fn get_file_mod_time(file_name: &[u8]) isize {
    return raw.GetFileModTime(z_ptr(file_name));
}

/// Get pointer to extension for a filename string (includes dot: '.png')
pub fn get_file_extension(file_name: &[u8]) &u8 {
    return raw.GetFileExtension(z_ptr(file_name));
}

/// Get pointer to filename for a path string
pub fn get_file_name(file_path: &[u8]) &u8 {
    return raw.GetFileName(z_ptr(file_path));
}

/// Get filename string without extension (uses static string)
pub fn get_file_name_without_ext(file_path: &[u8]) &u8 {
    return raw.GetFileNameWithoutExt(z_ptr(file_path));
}

/// Get full path for a given fileName with path (uses static string)
pub fn get_directory_path(file_path: &[u8]) &u8 {
    return raw.GetDirectoryPath(z_ptr(file_path));
}

/// Get previous directory path for a given path (uses static string)
pub fn get_prev_directory_path(dir_path: &[u8]) &u8 {
    return raw.GetPrevDirectoryPath(z_ptr(dir_path));
}

/// Get current working directory (uses static string)
pub fn get_working_directory() &u8 {
    return raw.GetWorkingDirectory();
}

/// Get the directory of the running application (uses static string)
pub fn get_application_directory() &u8 {
    return raw.GetApplicationDirectory();
}

/// Create directories (including full path requested), returns 0 on success
pub fn make_directory(dir_path: &[u8]) i32 {
    return raw.MakeDirectory(z_ptr(dir_path));
}

/// Change working directory, return true on success
pub fn change_directory(dir_path: &[u8]) bool {
    return raw.ChangeDirectory(z_ptr(dir_path));
}

/// Check if a given path is a file or a directory
pub fn is_path_file(path: &[u8]) bool {
    return raw.IsPathFile(z_ptr(path));
}

/// Check if fileName is valid for the platform/OS
pub fn is_file_name_valid(file_name: &[u8]) bool {
    return raw.IsFileNameValid(z_ptr(file_name));
}

/// Load directory filepaths, files and directories, no subdirs scan
pub fn load_directory_files(dir_path: &[u8]) FilePathList {
    return raw.LoadDirectoryFiles(z_ptr(dir_path));
}

/// Load directory filepaths with extension filtering and subdir scan; some filters available: "*.*", "FILES*", "DIRS*"
pub fn load_directory_files_ex(base_path: &[u8], filter: &[u8], scan_subdirs: bool) FilePathList {
    return raw.LoadDirectoryFilesEx(z_ptr(base_path), z_ptr(filter), scan_subdirs);
}

/// Unload filepaths
pub fn unload_directory_files(files: FilePathList) void {
    raw.UnloadDirectoryFiles(files);
}

/// Check if a file has been dropped into window
pub fn is_file_dropped() bool {
    return raw.IsFileDropped();
}

/// Load dropped filepaths
pub fn load_dropped_files() FilePathList {
    return raw.LoadDroppedFiles();
}

/// Unload dropped filepaths
pub fn unload_dropped_files(files: FilePathList) void {
    raw.UnloadDroppedFiles(files);
}

/// Get the file count in a directory
pub fn get_directory_file_count(dir_path: &[u8]) u32 {
    return raw.GetDirectoryFileCount(z_ptr(dir_path));
}

/// Get the file count in a directory with extension filtering and recursive directory scan. Use 'DIR' in the filter string to include directories in the result
pub fn get_directory_file_count_ex(base_path: &[u8], filter: &[u8], scan_subdirs: bool) u32 {
    return raw.GetDirectoryFileCountEx(z_ptr(base_path), z_ptr(filter), scan_subdirs);
}

/// Compress data (DEFLATE algorithm), memory must be MemFree()
pub fn compress_data(data: &u8, data_size: i32, comp_data_size: &mut i32) &u8 {
    return raw.CompressData(data, data_size, comp_data_size);
}

/// Decompress data (DEFLATE algorithm), memory must be MemFree()
pub fn decompress_data(comp_data: &u8, comp_data_size: i32, data_size: &mut i32) &u8 {
    return raw.DecompressData(comp_data, comp_data_size, data_size);
}

/// Encode data to Base64 string (includes NULL terminator), memory must be MemFree()
pub fn encode_data_base64(data: &u8, data_size: i32, output_size: &mut i32) &u8 {
    return raw.EncodeDataBase64(data, data_size, output_size);
}

/// Decode Base64 string (expected NULL terminated), memory must be MemFree()
pub fn decode_data_base64(text: &[u8], output_size: &mut i32) &u8 {
    return raw.DecodeDataBase64(z_ptr(text), output_size);
}

/// Compute CRC32 hash code
pub fn compute_crc32(data: &u8, data_size: i32) u32 {
    return raw.ComputeCRC32(data, data_size);
}

/// Compute MD5 hash code, returns static int[4] (16 bytes)
pub fn compute_md5(data: &u8, data_size: i32) &mut u32 {
    return raw.ComputeMD5(data, data_size);
}

/// Compute SHA1 hash code, returns static int[5] (20 bytes)
pub fn compute_sha1(data: &u8, data_size: i32) &mut u32 {
    return raw.ComputeSHA1(data, data_size);
}

/// Compute SHA256 hash code, returns static int[8] (32 bytes)
pub fn compute_sha256(data: &u8, data_size: i32) &mut u32 {
    return raw.ComputeSHA256(data, data_size);
}

/// Load automation events list from file, NULL for empty list, capacity = MAX_AUTOMATION_EVENTS
pub fn load_automation_event_list(file_name: &[u8]) AutomationEventList {
    return raw.LoadAutomationEventList(z_ptr(file_name));
}

/// Unload automation events list from file
pub fn unload_automation_event_list(list: AutomationEventList) void {
    raw.UnloadAutomationEventList(list);
}

/// Export automation events list as text file
pub fn export_automation_event_list(list: AutomationEventList, file_name: &[u8]) bool {
    return raw.ExportAutomationEventList(list, z_ptr(file_name));
}

/// Set automation event list to record to
pub fn set_automation_event_list(list: &mut AutomationEventList) void {
    raw.SetAutomationEventList(list);
}

/// Set automation event internal base frame to start recording
pub fn set_automation_event_base_frame(frame: i32) void {
    raw.SetAutomationEventBaseFrame(frame);
}

/// Start recording automation events (AutomationEventList must be set)
pub fn start_automation_event_recording() void {
    raw.StartAutomationEventRecording();
}

/// Stop recording automation events
pub fn stop_automation_event_recording() void {
    raw.StopAutomationEventRecording();
}

/// Play a recorded automation event
