}

/// Load materials from model file
pub fn load_materials(file_name: &[u8], material_count: &mut i32) &mut Material {
    return raw.LoadMaterials(z_ptr(file_name), material_count);
}

/// Load default material (Supports: DIFFUSE, SPECULAR, NORMAL maps)
pub fn load_material_default() Material {
    return raw.LoadMaterialDefault();
}

/// Check if a material is valid (shader assigned, map textures loaded in GPU)
pub fn is_material_valid(material: Material) bool {
    return raw.IsMaterialValid(material);
}

/// Unload material from GPU memory (VRAM)
pub fn unload_material(material: Material) void {
    raw.UnloadMaterial(material);
}

/// Set texture for a material map type (MATERIAL_MAP_DIFFUSE, MATERIAL_MAP_SPECULAR...)
pub fn set_material_texture(material: &mut Material, map_type: i32, texture: Texture2D) void {
    raw.SetMaterialTexture(material, map_type, texture);
}

/// Set material for a mesh
pub fn set_model_mesh_material(model: &mut Model, mesh_id: i32, material_id: i32) void {
    raw.SetModelMeshMaterial(model, mesh_id, material_id);
}

/// Load model animations from file
pub fn load_model_animations(file_name: &[u8], anim_count: &mut i32) &mut ModelAnimation {
    return raw.LoadModelAnimations(z_ptr(file_name), anim_count);
}

/// Update model animation pose (vertex buffers and bone matrices)
pub fn update_model_animation(model: Model, anim: ModelAnimation, frame: f32) void {
    raw.UpdateModelAnimation(model, anim, frame);
}

/// Update model animation pose, blending two animations
pub fn update_model_animation_ex(model: Model, anim_a: ModelAnimation, frame_a: f32, anim_b: ModelAnimation, frame_b: f32, blend: f32) void {
    raw.UpdateModelAnimationEx(model, anim_a, frame_a, anim_b, frame_b, blend);
}

/// Unload animation array data
pub fn unload_model_animations(animations: &mut ModelAnimation, anim_count: i32) void {
    raw.UnloadModelAnimations(animations, anim_count);
}

/// Check model animation skeleton match
pub fn is_model_animation_valid(model: Model, anim: ModelAnimation) bool {
    return raw.IsModelAnimationValid(model, anim);
}

/// Check collision between two spheres
pub fn check_collision_spheres(center1: Vector3, radius1: f32, center2: Vector3, radius2: f32) bool {
    return raw.CheckCollisionSpheres(center1, radius1, center2, radius2);
}

/// Check collision between two bounding boxes
pub fn check_collision_boxes(box1: BoundingBox, box2: BoundingBox) bool {
    return raw.CheckCollisionBoxes(box1, box2);
}

/// Check collision between box and sphere
pub fn check_collision_box_sphere(box: BoundingBox, center: Vector3, radius: f32) bool {
    return raw.CheckCollisionBoxSphere(box, center, radius);
}

/// Get collision info between ray and sphere
pub fn get_ray_collision_sphere(ray: Ray, center: Vector3, radius: f32) RayCollision {
    return raw.GetRayCollisionSphere(ray, center, radius);
}

/// Get collision info between ray and box
pub fn get_ray_collision_box(ray: Ray, box: BoundingBox) RayCollision {
    return raw.GetRayCollisionBox(ray, box);
}

/// Get collision info between ray and mesh
pub fn get_ray_collision_mesh(ray: Ray, mesh: Mesh, transform: Matrix) RayCollision {
    return raw.GetRayCollisionMesh(ray, mesh, transform);
}

/// Get collision info between ray and triangle
pub fn get_ray_collision_triangle(ray: Ray, p1: Vector3, p2: Vector3, p3: Vector3) RayCollision {
    return raw.GetRayCollisionTriangle(ray, p1, p2, p3);
}

/// Get collision info between ray and quad
pub fn get_ray_collision_quad(ray: Ray, p1: Vector3, p2: Vector3, p3: Vector3, p4: Vector3) RayCollision {
    return raw.GetRayCollisionQuad(ray, p1, p2, p3, p4);
}

/// Initialize audio device and context
pub fn init_audio_device() void {
    raw.InitAudioDevice();
}

/// Close the audio device and context
pub fn close_audio_device() void {
    raw.CloseAudioDevice();
}

/// Check if audio device has been initialized successfully
pub fn is_audio_device_ready() bool {
    return raw.IsAudioDeviceReady();
}

/// Set master volume (listener)
pub fn set_master_volume(volume: f32) void {
    raw.SetMasterVolume(volume);
}

/// Get master volume (listener)
pub fn get_master_volume() f32 {
    return raw.GetMasterVolume();
}

/// Load wave data from file
pub fn load_wave(file_name: &[u8]) Wave {
    return raw.LoadWave(z_ptr(file_name));
}

/// Load wave from memory buffer, fileType refers to extension: i.e. '.wav'
pub fn load_wave_from_memory(file_type: &[u8], file_data: &u8, data_size: i32) Wave {
    return raw.LoadWaveFromMemory(z_ptr(file_type), file_data, data_size);
}

/// Checks if wave data is valid (data loaded and parameters)
pub fn is_wave_valid(wave: Wave) bool {
    return raw.IsWaveValid(wave);
}

/// Load sound from file
pub fn load_sound(file_name: &[u8]) Sound {
    return raw.LoadSound(z_ptr(file_name));
}

/// Load sound from wave data
pub fn load_sound_from_wave(wave: Wave) Sound {
    return raw.LoadSoundFromWave(wave);
}

/// Create a new sound that shares the same sample data as the source sound, does not own the sound data
pub fn load_sound_alias(source: Sound) Sound {
    return raw.LoadSoundAlias(source);
}

/// Checks if a sound is valid (data loaded and buffers initialized)
pub fn is_sound_valid(sound: Sound) bool {
    return raw.IsSoundValid(sound);
}

/// Update sound buffer with new data (default data format: 32 bit float, stereo)
pub fn update_sound(sound: Sound, data: &mut void, sample_count: i32) void {
    raw.UpdateSound(sound, data, sample_count);
}

/// Unload wave data
pub fn unload_wave(wave: Wave) void {
    raw.UnloadWave(wave);
}

/// Unload sound
pub fn unload_sound(sound: Sound) void {
    raw.UnloadSound(sound);
}

/// Unload a sound alias (does not deallocate sample data)
pub fn unload_sound_alias(alias: Sound) void {
    raw.UnloadSoundAlias(alias);
}

/// Export wave data to file, returns true on success
pub fn export_wave(wave: Wave, file_name: &[u8]) bool {
    return raw.ExportWave(wave, z_ptr(file_name));
}

/// Export wave sample data to code (.h), returns true on success
pub fn export_wave_as_code(wave: Wave, file_name: &[u8]) bool {
    return raw.ExportWaveAsCode(wave, z_ptr(file_name));
}

/// Play a sound
pub fn play_sound(sound: Sound) void {
    raw.PlaySound(sound);
}

/// Stop playing a sound
pub fn stop_sound(sound: Sound) void {
    raw.StopSound(sound);
}

/// Pause a sound
pub fn pause_sound(sound: Sound) void {
    raw.PauseSound(sound);
}

/// Resume a paused sound
pub fn resume_sound(sound: Sound) void {
    raw.ResumeSound(sound);
}

/// Check if a sound is currently playing
pub fn is_sound_playing(sound: Sound) bool {
    return raw.IsSoundPlaying(sound);
}

/// Set volume for a sound (1.0 is max level)
pub fn set_sound_volume(sound: Sound, volume: f32) void {
    raw.SetSoundVolume(sound, volume);
}

/// Set pitch for a sound (1.0 is base level)
pub fn set_sound_pitch(sound: Sound, pitch: f32) void {
    raw.SetSoundPitch(sound, pitch);
}

/// Set pan for a sound (-1.0 left, 0.0 center, 1.0 right)
pub fn set_sound_pan(sound: Sound, pan: f32) void {
    raw.SetSoundPan(sound, pan);
}

/// Copy a wave to a new wave
pub fn wave_copy(wave: Wave) Wave {
    return raw.WaveCopy(wave);
}

/// Crop a wave to defined frames range
pub fn wave_crop(wave: &mut Wave, init_frame: i32, final_frame: i32) void {
    raw.WaveCrop(wave, init_frame, final_frame);
}

/// Convert wave data to desired format
pub fn wave_format(wave: &mut Wave, sample_rate: i32, sample_size: i32, channels: i32) void {
    raw.WaveFormat(wave, sample_rate, sample_size, channels);
}

/// Load samples data from wave as a 32bit float data array
pub fn load_wave_samples(wave: Wave) &mut f32 {
    return raw.LoadWaveSamples(wave);
}

/// Unload samples data loaded with LoadWaveSamples()
pub fn unload_wave_samples(samples: &mut f32) void {
    raw.UnloadWaveSamples(samples);
}

/// Load music stream from file
pub fn load_music_stream(file_name: &[u8]) Music {
    return raw.LoadMusicStream(z_ptr(file_name));
}

/// Load music stream from data
pub fn load_music_stream_from_memory(file_type: &[u8], data: &u8, data_size: i32) Music {
    return raw.LoadMusicStreamFromMemory(z_ptr(file_type), data, data_size);
}

/// Checks if a music stream is valid (context and buffers initialized)
pub fn is_music_valid(music: Music) bool {
    return raw.IsMusicValid(music);
}

/// Unload music stream
pub fn unload_music_stream(music: Music) void {
    raw.UnloadMusicStream(music);
}

/// Start music playing
pub fn play_music_stream(music: Music) void {
    raw.PlayMusicStream(music);
}

/// Check if music is playing
pub fn is_music_stream_playing(music: Music) bool {
    return raw.IsMusicStreamPlaying(music);
}

/// Updates buffers for music streaming
pub fn update_music_stream(music: Music) void {
    raw.UpdateMusicStream(music);
}

/// Stop music playing
pub fn stop_music_stream(music: Music) void {
    raw.StopMusicStream(music);
}

/// Pause music playing
pub fn pause_music_stream(music: Music) void {
    raw.PauseMusicStream(music);
}

/// Resume playing paused music
pub fn resume_music_stream(music: Music) void {
    raw.ResumeMusicStream(music);
}

/// Seek music to a position (in seconds)
pub fn seek_music_stream(music: Music, position: f32) void {
    raw.SeekMusicStream(music, position);
}

/// Set volume for music (1.0 is max level)
pub fn set_music_volume(music: Music, volume: f32) void {
    raw.SetMusicVolume(music, volume);
}

/// Set pitch for a music (1.0 is base level)
pub fn set_music_pitch(music: Music, pitch: f32) void {
    raw.SetMusicPitch(music, pitch);
}

/// Set pan for a music (-1.0 left, 0.0 center, 1.0 right)
pub fn set_music_pan(music: Music, pan: f32) void {
    raw.SetMusicPan(music, pan);
}

/// Get music time length (in seconds)
pub fn get_music_time_length(music: Music) f32 {
    return raw.GetMusicTimeLength(music);
}

/// Get current music time played (in seconds)
pub fn get_music_time_played(music: Music) f32 {
    return raw.GetMusicTimePlayed(music);
}

/// Load audio stream (to stream raw audio pcm data)
pub fn load_audio_stream(sample_rate: u32, sample_size: u32, channels: u32) AudioStream {
    return raw.LoadAudioStream(sample_rate, sample_size, channels);
}

/// Checks if an audio stream is valid (buffers initialized)
pub fn is_audio_stream_valid(stream: AudioStream) bool {
    return raw.IsAudioStreamValid(stream);
}

/// Unload audio stream and free memory
pub fn unload_audio_stream(stream: AudioStream) void {
    raw.UnloadAudioStream(stream);
}

/// Update audio stream buffers with data
pub fn update_audio_stream(stream: AudioStream, data: &mut void, frame_count: i32) void {
    raw.UpdateAudioStream(stream, data, frame_count);
}

/// Check if any audio stream buffers requires refill
pub fn is_audio_stream_processed(stream: AudioStream) bool {
    return raw.IsAudioStreamProcessed(stream);
}

/// Play audio stream
pub fn play_audio_stream(stream: AudioStream) void {
    raw.PlayAudioStream(stream);
}

/// Pause audio stream
pub fn pause_audio_stream(stream: AudioStream) void {
    raw.PauseAudioStream(stream);
}

/// Resume audio stream
pub fn resume_audio_stream(stream: AudioStream) void {
    raw.ResumeAudioStream(stream);
}

/// Check if audio stream is playing
pub fn is_audio_stream_playing(stream: AudioStream) bool {
    return raw.IsAudioStreamPlaying(stream);
}

/// Stop audio stream
pub fn stop_audio_stream(stream: AudioStream) void {
    raw.StopAudioStream(stream);
}

/// Set volume for audio stream (1.0 is max level)
pub fn set_audio_stream_volume(stream: AudioStream, volume: f32) void {
    raw.SetAudioStreamVolume(stream, volume);
}

/// Set pitch for audio stream (1.0 is base level)
pub fn set_audio_stream_pitch(stream: AudioStream, pitch: f32) void {
    raw.SetAudioStreamPitch(stream, pitch);
}

/// Set pan for audio stream (-1.0 to 1.0 range, 0.0 is centered)
pub fn set_audio_stream_pan(stream: AudioStream, pan: f32) void {
    raw.SetAudioStreamPan(stream, pan);
}

/// Default size for new audio streams
pub fn set_audio_stream_buffer_size_default(size: i32) void {
    raw.SetAudioStreamBufferSizeDefault(size);
}

