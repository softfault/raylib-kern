/// Check collision between two rectangles
pub fn check_collision_recs(rec1: Rectangle, rec2: Rectangle) bool {
    return raw.CheckCollisionRecs(rec1, rec2);
}

/// Check collision between two circles
pub fn check_collision_circles(center1: Vector2, radius1: f32, center2: Vector2, radius2: f32) bool {
    return raw.CheckCollisionCircles(center1, radius1, center2, radius2);
}

/// Check collision between circle and rectangle
pub fn check_collision_circle_rec(center: Vector2, radius: f32, rec: Rectangle) bool {
    return raw.CheckCollisionCircleRec(center, radius, rec);
}

/// Check if circle collides with a line created betweeen two points [p1] and [p2]
pub fn check_collision_circle_line(center: Vector2, radius: f32, p1: Vector2, p2: Vector2) bool {
    return raw.CheckCollisionCircleLine(center, radius, p1, p2);
}

/// Check if point is inside rectangle
pub fn check_collision_point_rec(point: Vector2, rec: Rectangle) bool {
    return raw.CheckCollisionPointRec(point, rec);
}

/// Check if point is inside circle
pub fn check_collision_point_circle(point: Vector2, center: Vector2, radius: f32) bool {
    return raw.CheckCollisionPointCircle(point, center, radius);
}

/// Check if point is inside a triangle
pub fn check_collision_point_triangle(point: Vector2, p1: Vector2, p2: Vector2, p3: Vector2) bool {
    return raw.CheckCollisionPointTriangle(point, p1, p2, p3);
}

/// Check if point belongs to line created between two points [p1] and [p2] with defined margin in pixels [threshold]
pub fn check_collision_point_line(point: Vector2, p1: Vector2, p2: Vector2, threshold: i32) bool {
    return raw.CheckCollisionPointLine(point, p1, p2, threshold);
}

/// Check if point is within a polygon described by array of vertices
pub fn check_collision_point_poly(point: Vector2, points: &mut Vector2, point_count: i32) bool {
    return raw.CheckCollisionPointPoly(point, points, point_count);
}

/// Check the collision between two lines defined by two points each, returns collision point by reference
pub fn check_collision_lines(start_pos1: Vector2, end_pos1: Vector2, start_pos2: Vector2, end_pos2: Vector2, collision_point: &mut Vector2) bool {
    return raw.CheckCollisionLines(start_pos1, end_pos1, start_pos2, end_pos2, collision_point);
}

/// Get collision rectangle for two rectangles collision
pub fn get_collision_rec(rec1: Rectangle, rec2: Rectangle) Rectangle {
    return raw.GetCollisionRec(rec1, rec2);
}

/// Load image from file into CPU memory (RAM)
pub fn load_image(file_name: &[u8]) Image {
    return raw.LoadImage(z_ptr(file_name));
}

/// Load image from RAW file data
pub fn load_image_raw(file_name: &[u8], width: i32, height: i32, format: i32, header_size: i32) Image {
    return raw.LoadImageRaw(z_ptr(file_name), width, height, format, header_size);
}

/// Load image sequence from file (frames appended to image.data)
pub fn load_image_anim(file_name: &[u8], frames: &mut i32) Image {
    return raw.LoadImageAnim(z_ptr(file_name), frames);
}

/// Load image sequence from memory buffer
pub fn load_image_anim_from_memory(file_type: &[u8], file_data: &u8, data_size: i32, frames: &mut i32) Image {
    return raw.LoadImageAnimFromMemory(z_ptr(file_type), file_data, data_size, frames);
}

/// Load image from memory buffer, fileType refers to extension: i.e. '.png'
pub fn load_image_from_memory(file_type: &[u8], file_data: &u8, data_size: i32) Image {
    return raw.LoadImageFromMemory(z_ptr(file_type), file_data, data_size);
}

/// Load image from GPU texture data
pub fn load_image_from_texture(texture: Texture2D) Image {
    return raw.LoadImageFromTexture(texture);
}

/// Load image from screen buffer and (screenshot)
pub fn load_image_from_screen() Image {
    return raw.LoadImageFromScreen();
}

/// Check if an image is valid (data and parameters)
pub fn is_image_valid(image: Image) bool {
    return raw.IsImageValid(image);
}

/// Unload image from CPU memory (RAM)
pub fn unload_image(image: Image) void {
    raw.UnloadImage(image);
}

/// Export image data to file, returns true on success
pub fn export_image(image: Image, file_name: &[u8]) bool {
    return raw.ExportImage(image, z_ptr(file_name));
}

/// Export image to memory buffer, memory must be MemFree()
pub fn export_image_to_memory(image: Image, file_type: &[u8], file_size: &mut i32) &u8 {
    return raw.ExportImageToMemory(image, z_ptr(file_type), file_size);
}

/// Export image as code file defining an array of bytes, returns true on success
pub fn export_image_as_code(image: Image, file_name: &[u8]) bool {
    return raw.ExportImageAsCode(image, z_ptr(file_name));
}

/// Generate image: plain color
pub fn gen_image_color(width: i32, height: i32, color: Color) Image {
    return raw.GenImageColor(width, height, color);
}

/// Generate image: linear gradient, direction in degrees [0..360], 0=Vertical gradient
pub fn gen_image_gradient_linear(width: i32, height: i32, direction: i32, start: Color, end: Color) Image {
    return raw.GenImageGradientLinear(width, height, direction, start, end);
}

/// Generate image: radial gradient
pub fn gen_image_gradient_radial(width: i32, height: i32, density: f32, inner: Color, outer: Color) Image {
    return raw.GenImageGradientRadial(width, height, density, inner, outer);
}

/// Generate image: square gradient
pub fn gen_image_gradient_square(width: i32, height: i32, density: f32, inner: Color, outer: Color) Image {
    return raw.GenImageGradientSquare(width, height, density, inner, outer);
}

/// Generate image: checked
pub fn gen_image_checked(width: i32, height: i32, checks_x: i32, checks_y: i32, col1: Color, col2: Color) Image {
    return raw.GenImageChecked(width, height, checks_x, checks_y, col1, col2);
}

/// Generate image: white noise
pub fn gen_image_white_noise(width: i32, height: i32, factor: f32) Image {
    return raw.GenImageWhiteNoise(width, height, factor);
}

/// Generate image: perlin noise
pub fn gen_image_perlin_noise(width: i32, height: i32, offset_x: i32, offset_y: i32, scale: f32) Image {
    return raw.GenImagePerlinNoise(width, height, offset_x, offset_y, scale);
}

/// Generate image: cellular algorithm, bigger tileSize means bigger cells
pub fn gen_image_cellular(width: i32, height: i32, tile_size: i32) Image {
    return raw.GenImageCellular(width, height, tile_size);
}

/// Generate image: grayscale image from text data
pub fn gen_image_text(width: i32, height: i32, text: &[u8]) Image {
    return raw.GenImageText(width, height, z_ptr(text));
}

/// Create an image duplicate (useful for transformations)
pub fn image_copy(image: Image) Image {
    return raw.ImageCopy(image);
}

/// Create an image from another image piece
pub fn image_from_image(image: Image, rec: Rectangle) Image {
    return raw.ImageFromImage(image, rec);
}

/// Create an image from a selected channel of another image (GRAYSCALE)
pub fn image_from_channel(image: Image, selected_channel: i32) Image {
    return raw.ImageFromChannel(image, selected_channel);
}

/// Create an image from text (default font)
pub fn image_text(text: &[u8], font_size: i32, color: Color) Image {
    return raw.ImageText(z_ptr(text), font_size, color);
}

/// Create an image from text (custom sprite font)
pub fn image_text_ex(font: Font, text: &[u8], font_size: f32, spacing: f32, tint: Color) Image {
    return raw.ImageTextEx(font, z_ptr(text), font_size, spacing, tint);
}

/// Convert image data to desired format
pub fn image_format(image: &mut Image, new_format: i32) void {
    raw.ImageFormat(image, new_format);
}

/// Convert image to POT (power-of-two)
pub fn image_to_pot(image: &mut Image, fill: Color) void {
    raw.ImageToPOT(image, fill);
}

/// Crop an image to a defined rectangle
pub fn image_crop(image: &mut Image, crop: Rectangle) void {
    raw.ImageCrop(image, crop);
}

/// Crop image depending on alpha value
