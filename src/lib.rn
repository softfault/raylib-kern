    raw.PlayAutomationEvent(event);
}

/// Check if a key has been pressed once
pub fn is_key_pressed(key: KeyboardKey) bool {
    return raw.IsKeyPressed(key);
}

/// Check if a key has been pressed again
pub fn is_key_pressed_repeat(key: KeyboardKey) bool {
    return raw.IsKeyPressedRepeat(key);
}

/// Check if a key is being pressed
pub fn is_key_down(key: KeyboardKey) bool {
    return raw.IsKeyDown(key);
}

/// Check if a key has been released once
pub fn is_key_released(key: KeyboardKey) bool {
    return raw.IsKeyReleased(key);
}

/// Check if a key is NOT being pressed
pub fn is_key_up(key: KeyboardKey) bool {
    return raw.IsKeyUp(key);
}

/// Get key pressed (keycode), call it multiple times for keys queued, returns 0 when the queue is empty
pub fn get_key_pressed() i32 {
    return raw.GetKeyPressed();
}

/// Get char pressed (unicode), call it multiple times for chars queued, returns 0 when the queue is empty
pub fn get_char_pressed() i32 {
    return raw.GetCharPressed();
}

/// Get name of a QWERTY key on the current keyboard layout (eg returns string 'q' for KEY_A on an AZERTY keyboard)
pub fn get_key_name(key: KeyboardKey) &u8 {
    return raw.GetKeyName(key);
}

/// Set a custom key to exit program (default is ESC)
pub fn set_exit_key(key: KeyboardKey) void {
    raw.SetExitKey(key);
}

