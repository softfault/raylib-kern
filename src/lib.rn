pub const BEIGE = Color.{ r: 211, g: 176, b: 131, a: 255 };
/// Brown
pub const BROWN = Color.{ r: 127, g: 106, b: 79, a: 255 };
/// Dark Brown
pub const DARKBROWN = Color.{ r: 76, g: 63, b: 47, a: 255 };
