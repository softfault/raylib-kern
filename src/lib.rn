    raw.SetTextureWrap(texture, wrap);
}

/// Draw a Texture2D
pub fn draw_texture(texture: Texture2D, pos_x: i32, pos_y: i32, tint: Color) void {
    raw.DrawTexture(texture, pos_x, pos_y, tint);
}

/// Draw a Texture2D with position defined as Vector2
pub fn draw_texture_v(texture: Texture2D, position: Vector2, tint: Color) void {
    raw.DrawTextureV(texture, position, tint);
}

/// Draw a Texture2D with extended parameters
pub fn draw_texture_ex(texture: Texture2D, position: Vector2, rotation: f32, scale: f32, tint: Color) void {
    raw.DrawTextureEx(texture, position, rotation, scale, tint);
}

/// Draw a part of a texture defined by a rectangle
pub fn draw_texture_rec(texture: Texture2D, source: Rectangle, position: Vector2, tint: Color) void {
    raw.DrawTextureRec(texture, source, position, tint);
}

/// Draw a part of a texture defined by a rectangle with 'pro' parameters
pub fn draw_texture_pro(texture: Texture2D, source: Rectangle, dest: Rectangle, origin: Vector2, rotation: f32, tint: Color) void {
    raw.DrawTexturePro(texture, source, dest, origin, rotation, tint);
}

/// Draws a texture (or part of it) that stretches or shrinks nicely
pub fn draw_texture_n_patch(texture: Texture2D, n_patch_info: NPatchInfo, dest: Rectangle, origin: Vector2, rotation: f32, tint: Color) void {
    raw.DrawTextureNPatch(texture, n_patch_info, dest, origin, rotation, tint);
}

/// Check if two colors are equal
pub fn color_is_equal(col1: Color, col2: Color) bool {
    return raw.ColorIsEqual(col1, col2);
}

/// Get color with alpha applied, alpha goes from 0.0f to 1.0f
pub fn fade(color: Color, alpha: f32) Color {
    return raw.Fade(color, alpha);
}

/// Get hexadecimal value for a Color (0xRRGGBBAA)
pub fn color_to_int(color: Color) i32 {
    return raw.ColorToInt(color);
}

/// Get Color normalized as float [0..1]
pub fn color_normalize(color: Color) Vector4 {
    return raw.ColorNormalize(color);
}

/// Get Color from normalized values [0..1]
pub fn color_from_normalized(normalized: Vector4) Color {
    return raw.ColorFromNormalized(normalized);
}

/// Get HSV values for a Color, hue [0..360], saturation/value [0..1]
pub fn color_to_hsv(color: Color) Vector3 {
    return raw.ColorToHSV(color);
}

/// Get a Color from HSV values, hue [0..360], saturation/value [0..1]
pub fn color_from_hsv(hue: f32, saturation: f32, value: f32) Color {
    return raw.ColorFromHSV(hue, saturation, value);
}

/// Get color multiplied with another color
pub fn color_tint(color: Color, tint: Color) Color {
    return raw.ColorTint(color, tint);
}

/// Get color with brightness correction, brightness factor goes from -1.0f to 1.0f
pub fn color_brightness(color: Color, factor: f32) Color {
    return raw.ColorBrightness(color, factor);
}

/// Get color with contrast correction, contrast values between -1.0f and 1.0f
pub fn color_contrast(color: Color, contrast: f32) Color {
    return raw.ColorContrast(color, contrast);
}

/// Get color with alpha applied, alpha goes from 0.0f to 1.0f
pub fn color_alpha(color: Color, alpha: f32) Color {
    return raw.ColorAlpha(color, alpha);
}

/// Get src alpha-blended into dst color with tint
pub fn color_alpha_blend(dst: Color, src: Color, tint: Color) Color {
    return raw.ColorAlphaBlend(dst, src, tint);
}

/// Get color lerp interpolation between two colors, factor [0.0f..1.0f]
pub fn color_lerp(color1: Color, color2: Color, factor: f32) Color {
    return raw.ColorLerp(color1, color2, factor);
}

/// Get Color structure from hexadecimal value
pub fn get_color(hex_value: u32) Color {
    return raw.GetColor(hex_value);
}

/// Get Color from a source pixel pointer of certain format
pub fn get_pixel_color(src_ptr: &mut void, format: i32) Color {
    return raw.GetPixelColor(src_ptr, format);
}

/// Set color formatted into destination pixel pointer
pub fn set_pixel_color(dst_ptr: &mut void, color: Color, format: i32) void {
    raw.SetPixelColor(dst_ptr, color, format);
}

/// Get pixel data size in bytes for certain format
pub fn get_pixel_data_size(width: i32, height: i32, format: i32) i32 {
    return raw.GetPixelDataSize(width, height, format);
}

/// Get the default Font
pub fn get_font_default() Font {
    return raw.GetFontDefault();
}

/// Load font from file into GPU memory (VRAM)
pub fn load_font(file_name: &[u8]) Font {
    return raw.LoadFont(z_ptr(file_name));
}

/// Load font from file with extended parameters, use NULL for codepoints and 0 for codepointCount to load the default character set, font size is provided in pixels height
pub fn load_font_ex(file_name: &[u8], font_size: i32, codepoints: &mut i32, codepoint_count: i32) Font {
    return raw.LoadFontEx(z_ptr(file_name), font_size, codepoints, codepoint_count);
}

/// Load font from Image (XNA style)
pub fn load_font_from_image(image: Image, key: Color, first_char: i32) Font {
    return raw.LoadFontFromImage(image, key, first_char);
}

/// Load font from memory buffer, fileType refers to extension: i.e. '.ttf'
pub fn load_font_from_memory(file_type: &[u8], file_data: &u8, data_size: i32, font_size: i32, codepoints: &mut i32, codepoint_count: i32) Font {
    return raw.LoadFontFromMemory(z_ptr(file_type), file_data, data_size, font_size, codepoints, codepoint_count);
}

/// Check if a font is valid (font data loaded, WARNING: GPU texture not checked)
pub fn is_font_valid(font: Font) bool {
    return raw.IsFontValid(font);
}

/// Load font data for further use
pub fn load_font_data(file_data: &u8, data_size: i32, font_size: i32, codepoints: &mut i32, codepoint_count: i32, kind: i32, glyph_count: &mut i32) &mut GlyphInfo {
    return raw.LoadFontData(file_data, data_size, font_size, codepoints, codepoint_count, kind, glyph_count);
}

/// Generate image font atlas using chars info
pub fn gen_image_font_atlas(glyphs: &mut GlyphInfo, glyph_recs: &mut &mut Rectangle, glyph_count: i32, font_size: i32, padding: i32, pack_method: i32) Image {
    return raw.GenImageFontAtlas(glyphs, glyph_recs, glyph_count, font_size, padding, pack_method);
}

/// Unload font chars info data (RAM)
pub fn unload_font_data(glyphs: &mut GlyphInfo, glyph_count: i32) void {
    raw.UnloadFontData(glyphs, glyph_count);
}

/// Unload font from GPU memory (VRAM)
pub fn unload_font(font: Font) void {
    raw.UnloadFont(font);
}

/// Export font as code file, returns true on success
pub fn export_font_as_code(font: Font, file_name: &[u8]) bool {
    return raw.ExportFontAsCode(font, z_ptr(file_name));
}

/// Draw current FPS
pub fn draw_fps(pos_x: i32, pos_y: i32) void {
    raw.DrawFPS(pos_x, pos_y);
}

/// Draw text (using default font)
pub fn draw_text(text: &[u8], pos_x: i32, pos_y: i32, font_size: i32, color: Color) void {
    raw.DrawText(z_ptr(text), pos_x, pos_y, font_size, color);
}

/// Draw text using font and additional parameters
pub fn draw_text_ex(font: Font, text: &[u8], position: Vector2, font_size: f32, spacing: f32, tint: Color) void {
    raw.DrawTextEx(font, z_ptr(text), position, font_size, spacing, tint);
}

/// Draw text using Font and pro parameters (rotation)
pub fn draw_text_pro(font: Font, text: &[u8], position: Vector2, origin: Vector2, rotation: f32, font_size: f32, spacing: f32, tint: Color) void {
    raw.DrawTextPro(font, z_ptr(text), position, origin, rotation, font_size, spacing, tint);
}

/// Draw one character (codepoint)
pub fn draw_text_codepoint(font: Font, codepoint: i32, position: Vector2, font_size: f32, tint: Color) void {
    raw.DrawTextCodepoint(font, codepoint, position, font_size, tint);
}

/// Draw multiple character (codepoint)
pub fn draw_text_codepoints(font: Font, codepoints: &mut i32, codepoint_count: i32, position: Vector2, font_size: f32, spacing: f32, tint: Color) void {
    raw.DrawTextCodepoints(font, codepoints, codepoint_count, position, font_size, spacing, tint);
}

/// Set vertical line spacing when drawing with line-breaks
pub fn set_text_line_spacing(spacing: i32) void {
    raw.SetTextLineSpacing(spacing);
}

/// Measure string width for default font
pub fn measure_text(text: &[u8], font_size: i32) i32 {
    return raw.MeasureText(z_ptr(text), font_size);
}

/// Measure string size for Font
pub fn measure_text_ex(font: Font, text: &[u8], font_size: f32, spacing: f32) Vector2 {
    return raw.MeasureTextEx(font, z_ptr(text), font_size, spacing);
}

/// Measure string size for an existing array of codepoints for Font
pub fn measure_text_codepoints(font: Font, codepoints: &mut i32, length: i32, font_size: f32, spacing: f32) Vector2 {
    return raw.MeasureTextCodepoints(font, codepoints, length, font_size, spacing);
}

/// Get glyph index position in font for a codepoint (unicode character), fallback to '?' if not found
pub fn get_glyph_index(font: Font, codepoint: i32) i32 {
    return raw.GetGlyphIndex(font, codepoint);
}

/// Get glyph font info data for a codepoint (unicode character), fallback to '?' if not found
pub fn get_glyph_info(font: Font, codepoint: i32) GlyphInfo {
    return raw.GetGlyphInfo(font, codepoint);
}

/// Get glyph rectangle in font atlas for a codepoint (unicode character), fallback to '?' if not found
pub fn get_glyph_atlas_rec(font: Font, codepoint: i32) Rectangle {
    return raw.GetGlyphAtlasRec(font, codepoint);
}

/// Load UTF-8 text encoded from codepoints array
pub fn load_utf8(codepoints: &mut i32, length: i32) &u8 {
    return raw.LoadUTF8(codepoints, length);
}

/// Unload UTF-8 text encoded from codepoints array
pub fn unload_utf8(text: &[u8]) void {
    raw.UnloadUTF8(z_ptr(text));
}

/// Load all codepoints from a UTF-8 text string, codepoints count returned by parameter
pub fn load_codepoints(text: &[u8], count: &mut i32) &mut i32 {
    return raw.LoadCodepoints(z_ptr(text), count);
}

/// Unload codepoints data from memory
pub fn unload_codepoints(codepoints: &mut i32) void {
    raw.UnloadCodepoints(codepoints);
}

/// Get total number of codepoints in a UTF-8 encoded string
pub fn get_codepoint_count(text: &[u8]) i32 {
    return raw.GetCodepointCount(z_ptr(text));
}

/// Get next codepoint in a UTF-8 encoded string, 0x3f('?') is returned on failure
pub fn get_codepoint(text: &[u8], codepoint_size: &mut i32) i32 {
    return raw.GetCodepoint(z_ptr(text), codepoint_size);
}

/// Get next codepoint in a UTF-8 encoded string, 0x3f('?') is returned on failure
pub fn get_codepoint_next(text: &[u8], codepoint_size: &mut i32) i32 {
    return raw.GetCodepointNext(z_ptr(text), codepoint_size);
}

/// Get previous codepoint in a UTF-8 encoded string, 0x3f('?') is returned on failure
pub fn get_codepoint_previous(text: &[u8], codepoint_size: &mut i32) i32 {
    return raw.GetCodepointPrevious(z_ptr(text), codepoint_size);
}

/// Encode one codepoint into UTF-8 byte array (array length returned as parameter)
pub fn codepoint_to_utf8(codepoint: i32, utf8_size: &mut i32) &u8 {
    return raw.CodepointToUTF8(codepoint, utf8_size);
}

/// Load text as separate lines ('\n')
pub fn load_text_lines(text: &[u8], count: &mut i32) &mut &u8 {
    return raw.LoadTextLines(z_ptr(text), count);
}

/// Unload text lines
pub fn unload_text_lines(text: &mut &u8, line_count: i32) void {
    raw.UnloadTextLines(text, line_count);
}

/// Copy one string to another, returns bytes copied
pub fn text_copy(dst: &[u8], src: &[u8]) i32 {
    return raw.TextCopy(z_ptr(dst), z_ptr(src));
}

/// Check if two text string are equal
pub fn text_is_equal(text1: &[u8], text2: &[u8]) bool {
    return raw.TextIsEqual(z_ptr(text1), z_ptr(text2));
}

/// Get text length, checks for '\0' ending
pub fn text_length(text: &[u8]) u32 {
    return raw.TextLength(z_ptr(text));
}

/// Get a piece of a text string
pub fn text_subtext(text: &[u8], position: i32, length: i32) &u8 {
    return raw.TextSubtext(z_ptr(text), position, length);
}

/// Remove text spaces, concat words
pub fn text_remove_spaces(text: &[u8]) &u8 {
    return raw.TextRemoveSpaces(z_ptr(text));
}

/// Get text between two strings
pub fn get_text_between(text: &[u8], begin: &[u8], end: &[u8]) &u8 {
    return raw.GetTextBetween(z_ptr(text), z_ptr(begin), z_ptr(end));
}

/// Replace text string with new string
pub fn text_replace(text: &[u8], search: &[u8], replacement: &[u8]) &u8 {
    return raw.TextReplace(z_ptr(text), z_ptr(search), z_ptr(replacement));
}

/// Replace text string with new string, memory must be MemFree()
pub fn text_replace_alloc(text: &[u8], search: &[u8], replacement: &[u8]) &u8 {
    return raw.TextReplaceAlloc(z_ptr(text), z_ptr(search), z_ptr(replacement));
}

/// Replace text between two specific strings
pub fn text_replace_between(text: &[u8], begin: &[u8], end: &[u8], replacement: &[u8]) &u8 {
    return raw.TextReplaceBetween(z_ptr(text), z_ptr(begin), z_ptr(end), z_ptr(replacement));
}

/// Replace text between two specific strings, memory must be MemFree()
pub fn text_replace_between_alloc(text: &[u8], begin: &[u8], end: &[u8], replacement: &[u8]) &u8 {
    return raw.TextReplaceBetweenAlloc(z_ptr(text), z_ptr(begin), z_ptr(end), z_ptr(replacement));
}

/// Insert text in a defined byte position
pub fn text_insert(text: &[u8], insert: &[u8], position: i32) &u8 {
    return raw.TextInsert(z_ptr(text), z_ptr(insert), position);
}

/// Insert text in a defined byte position, memory must be MemFree()
pub fn text_insert_alloc(text: &[u8], insert: &[u8], position: i32) &u8 {
    return raw.TextInsertAlloc(z_ptr(text), z_ptr(insert), position);
}

/// Join text strings with delimiter
pub fn text_join(text_list: &mut &u8, count: i32, delimiter: &[u8]) &u8 {
    return raw.TextJoin(text_list, count, z_ptr(delimiter));
}

/// Split text into multiple strings, using MAX_TEXTSPLIT_COUNT static strings
pub fn text_split(text: &[u8], delimiter: u8, count: &mut i32) &mut &u8 {
    return raw.TextSplit(z_ptr(text), delimiter, count);
}

/// Append text at specific position and move cursor
pub fn text_append(text: &[u8], append: &[u8], position: &mut i32) void {
    raw.TextAppend(z_ptr(text), z_ptr(append), position);
}

/// Find first text occurrence within a string, -1 if not found
pub fn text_find_index(text: &[u8], search: &[u8]) i32 {
    return raw.TextFindIndex(z_ptr(text), z_ptr(search));
}

/// Get upper case version of provided string
pub fn text_to_upper(text: &[u8]) &u8 {
    return raw.TextToUpper(z_ptr(text));
}

/// Get lower case version of provided string
pub fn text_to_lower(text: &[u8]) &u8 {
    return raw.TextToLower(z_ptr(text));
}

/// Get Pascal case notation version of provided string
pub fn text_to_pascal(text: &[u8]) &u8 {
    return raw.TextToPascal(z_ptr(text));
}

/// Get Snake case notation version of provided string
pub fn text_to_snake(text: &[u8]) &u8 {
    return raw.TextToSnake(z_ptr(text));
}

/// Get Camel case notation version of provided string
pub fn text_to_camel(text: &[u8]) &u8 {
    return raw.TextToCamel(z_ptr(text));
}

/// Get integer value from text
pub fn text_to_integer(text: &[u8]) i32 {
    return raw.TextToInteger(z_ptr(text));
}

/// Get float value from text
pub fn text_to_float(text: &[u8]) f32 {
    return raw.TextToFloat(z_ptr(text));
}

