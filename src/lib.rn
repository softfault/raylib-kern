    raw.ImageAlphaCrop(image, threshold);
}

/// Clear alpha channel to desired color
pub fn image_alpha_clear(image: &mut Image, color: Color, threshold: f32) void {
    raw.ImageAlphaClear(image, color, threshold);
}

/// Apply alpha mask to image
pub fn image_alpha_mask(image: &mut Image, alpha_mask: Image) void {
    raw.ImageAlphaMask(image, alpha_mask);
}

/// Premultiply alpha channel
pub fn image_alpha_premultiply(image: &mut Image) void {
    raw.ImageAlphaPremultiply(image);
}

/// Apply Gaussian blur using a box blur approximation
pub fn image_blur_gaussian(image: &mut Image, blur_size: i32) void {
    raw.ImageBlurGaussian(image, blur_size);
}

/// Apply custom square convolution kernel to image
pub fn image_kernel_convolution(image: &mut Image, kernel: &mut f32, kernel_size: i32) void {
