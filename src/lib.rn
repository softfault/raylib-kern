//! Kern-style raylib API.
//!
//! This module is generated from raylib's rlparser metadata and wraps
//! the private `raw` ABI module with snake_case functions and slice-based
//! C string inputs.

mod raw;
mod internal;

use .internal.z_ptr;

pub const RAYLIB_VERSION_MAJOR = 6;
pub const RAYLIB_VERSION_MINOR = 0;
pub const RAYLIB_VERSION_PATCH = 0;
