}

/// Compute mesh tangents
pub fn gen_mesh_tangents(mesh: &mut Mesh) void {
    raw.GenMeshTangents(mesh);
}

/// Export mesh data to file, returns true on success
pub fn export_mesh(mesh: Mesh, file_name: &[u8]) bool {
    return raw.ExportMesh(mesh, z_ptr(file_name));
}

/// Export mesh as code file (.h) defining multiple arrays of vertex attributes
pub fn export_mesh_as_code(mesh: Mesh, file_name: &[u8]) bool {
    return raw.ExportMeshAsCode(mesh, z_ptr(file_name));
}

/// Generate polygonal mesh
pub fn gen_mesh_poly(sides: i32, radius: f32) Mesh {
    return raw.GenMeshPoly(sides, radius);
}

/// Generate plane mesh (with subdivisions)
pub fn gen_mesh_plane(width: f32, length: f32, res_x: i32, res_z: i32) Mesh {
    return raw.GenMeshPlane(width, length, res_x, res_z);
}

/// Generate cuboid mesh
pub fn gen_mesh_cube(width: f32, height: f32, length: f32) Mesh {
    return raw.GenMeshCube(width, height, length);
}

/// Generate sphere mesh (standard sphere)
pub fn gen_mesh_sphere(radius: f32, rings: i32, slices: i32) Mesh {
    return raw.GenMeshSphere(radius, rings, slices);
}

/// Generate half-sphere mesh (no bottom cap)
pub fn gen_mesh_hemi_sphere(radius: f32, rings: i32, slices: i32) Mesh {
    return raw.GenMeshHemiSphere(radius, rings, slices);
}

/// Generate cylinder mesh
pub fn gen_mesh_cylinder(radius: f32, height: f32, slices: i32) Mesh {
    return raw.GenMeshCylinder(radius, height, slices);
}

/// Generate cone/pyramid mesh
pub fn gen_mesh_cone(radius: f32, height: f32, slices: i32) Mesh {
    return raw.GenMeshCone(radius, height, slices);
}

/// Generate torus mesh
pub fn gen_mesh_torus(radius: f32, size: f32, rad_seg: i32, sides: i32) Mesh {
    return raw.GenMeshTorus(radius, size, rad_seg, sides);
}

/// Generate trefoil knot mesh
pub fn gen_mesh_knot(radius: f32, size: f32, rad_seg: i32, sides: i32) Mesh {
    return raw.GenMeshKnot(radius, size, rad_seg, sides);
}

/// Generate heightmap mesh from image data
