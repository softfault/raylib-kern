/// Draws a line inside an image from vector positions.
pub fn image_draw_line_v(dst: &mut Image, start: Vector2, end: Vector2, color: Color) void {
    raw.ImageDrawLineV(
        dst,
        start,
        end,
        color,
    );
}

/// Draws a thick line inside an image.
pub fn image_draw_line_ex(
    dst: &mut Image,
    start: Vector2,
    end: Vector2,
    thick: i32,
    color: Color,
) void {
    raw.ImageDrawLineEx(
        dst,
        start,
        end,
        thick,
        color,
    );
}

/// Draws a filled circle inside an image.
pub fn image_draw_circle(dst: &mut Image, x: i32, y: i32, radius: i32, color: Color) void {
    raw.ImageDrawCircle(
        dst,
        x,
        y,
        radius,
        color,
    );
}

/// Draws a filled circle inside an image from a vector center.
pub fn image_draw_circle_v(dst: &mut Image, center: Vector2, radius: i32, color: Color) void {
    raw.ImageDrawCircleV(
        dst,
        center,
        radius,
        color,
    );
}

/// Draws a circle outline inside an image.
pub fn image_draw_circle_lines(dst: &mut Image, x: i32, y: i32, radius: i32, color: Color) void {
    raw.ImageDrawCircleLines(
        dst,
        x,
        y,
        radius,
        color,
    );
}

/// Draws a circle outline inside an image from a vector center.
pub fn image_draw_circle_lines_v(dst: &mut Image, center: Vector2, radius: i32, color: Color) void {
    raw.ImageDrawCircleLinesV(
        dst,
        center,
        radius,
        color,
    );
}

/// Draws a rectangle inside an image.
pub fn image_draw_rectangle(
    dst: &mut Image,
    x: i32,
    y: i32,
    width: i32,
    height: i32,
    color: Color,
) void {
    raw.ImageDrawRectangle(
        dst,
        x,
        y,
        width,
        height,
        color,
    );
}

/// Draws a rectangle inside an image from vector position and size.
pub fn image_draw_rectangle_v(
    dst: &mut Image,
    position: Vector2,
    size: Vector2,
    color: Color,
) void {
    raw.ImageDrawRectangleV(
        dst,
        position,
        size,
        color,
    );
}

/// Draws a rectangle inside an image.
pub fn image_draw_rectangle_rec(dst: &mut Image, rect: Rectangle, color: Color) void {
    raw.ImageDrawRectangleRec(dst, rect, color);
}

/// Draws a rectangle outline inside an image.
pub fn image_draw_rectangle_lines(dst: &mut Image, rect: Rectangle, thick: i32, color: Color) void {
    raw.ImageDrawRectangleLines(
        dst,
        rect,
        thick,
        color,
    );
}

/// Draws a filled triangle inside an image.
pub fn image_draw_triangle(
    dst: &mut Image,
    v1: Vector2,
    v2: Vector2,
    v3: Vector2,
    color: Color,
) void {
    raw.ImageDrawTriangle(
        dst,
        v1,
        v2,
        v3,
        color,
    );
}

/// Draws a triangle with interpolated vertex colors inside an image.
pub fn image_draw_triangle_ex(
    dst: &mut Image,
    v1: Vector2,
    v2: Vector2,
    v3: Vector2,
    c1: Color,
    c2: Color,
    c3: Color,
) void {
    raw.ImageDrawTriangleEx(
        dst,
        v1,
        v2,
        v3,
        c1,
        c2,
        c3,
    );
}

/// Draws a triangle outline inside an image.
pub fn image_draw_triangle_lines(
    dst: &mut Image,
    v1: Vector2,
    v2: Vector2,
    v3: Vector2,
    color: Color,
) void {
    raw.ImageDrawTriangleLines(
        dst,
        v1,
        v2,
        v3,
        color,
    );
}

/// Draws a triangle fan inside an image.
pub fn image_draw_triangle_fan(
    dst: &mut Image,
    points: &mut Vector2,
    point_count: i32,
    color: Color,
) void {
    raw.ImageDrawTriangleFan(
        dst,
        points,
        point_count,
        color,
    );
}

/// Draws a triangle strip inside an image.
pub fn image_draw_triangle_strip(
    dst: &mut Image,
    points: &mut Vector2,
    point_count: i32,
    color: Color,
) void {
    raw.ImageDrawTriangleStrip(
        dst,
        points,
        point_count,
        color,
    );
}

/// Draws a source image into a destination image.
pub fn image_draw(
    dst: &mut Image,
    src: Image,
    src_rect: Rectangle,
    dst_rect: Rectangle,
    tint: Color,
) void {
    raw.ImageDraw(
        dst,
        src,
        src_rect,
        dst_rect,
        tint,
    );
}

/// Draws text into an image using the default font.
pub fn image_draw_text(
    dst: &mut Image,
    text: &[u8],
    x: i32,
    y: i32,
    font_size: i32,
    color: Color,
) void {
    raw.ImageDrawText(
        dst,
        z_ptr(text),
        x,
        y,
        font_size,
        color,
    );
}

/// Draws text into an image using a custom font.
pub fn image_draw_text_ex(
    dst: &mut Image,
    font: Font,
    text: &[u8],
    position: Vector2,
    font_size: f32,
    spacing: f32,
    tint: Color,
) void {
    raw.ImageDrawTextEx(
        dst,
        font,
        z_ptr(text),
        position,
        font_size,
        spacing,
        tint,
    );
}
