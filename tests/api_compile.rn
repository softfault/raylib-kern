//! Compile-time coverage for the public wrapper API surface.

use raylib;

const TITLE = "compile-only\0";
const TEXT = "hello\0";
const TEXTURE_PATH = "missing.png\0";

// Locks shader resource methods without requiring a real shader asset.
fn use_shader_api() void {
    let shader = raylib.shaders.load_shader("missing.vs\0", "missing.fs\0");
    let mut tint_value = raylib.WHITE.normalize();
    let tint = shader.location("tint\0");
    _ = shader.is_valid();
    _ = shader.attrib_location("position\0");
    _ = shader.set_value(tint, tint_value..&, raylib.ShaderUniformDataType.VEC4);
    shader.unload();
}

// Locks custom-font and zero-terminated text receiver methods.
fn use_text_api() void {
    let font = raylib.text.load_font("missing.ttf\0");
    let mut count = 0;
    let mut size = 0;
    _ = font.is_valid();
    _ = font.measure(
        TEXT,
        20.0,
        1.0,
    );
    _ = font.glyph_index(65);
    _ = TEXT.codepoint_count();
    _ = TEXT.z_len();
    _ = TEXT.text_eq(TEXT);
    _ = TEXT.find_text("ll\0");
    _ = "42\0".to_integer();
    _ = "3.5\0".to_float();
    _ = TEXT.codepoints(count..&);
    _ = TEXT.codepoint(size..&);
    _ = TEXT.next_codepoint(size..&);
    _ = TEXT.previous_codepoint(size..&);
    _ = TEXT.subtext(0, 2);
    _ = "hello world\0".without_spaces();
    _ = TEXT.between("h\0", "o\0");
    _ = TEXT.replace("h\0", "H\0");
    _ = TEXT.insert("!\0", 5);
    _ = TEXT.split(u8.{44}, count..&);
    _ = TEXT.to_snake();
    _ = TEXT.to_camel();
    _ = font.draw(
        TEXT,
        raylib.vector2(0.0, 0.0),
        20.0,
        1.0,
        raylib.WHITE,
    );
    font.unload();
}

// Locks model, mesh, material, and 3D collision receiver methods.
fn use_model_api() void {
    let pos = raylib.vector3(0.0, 0.0, 0.0);
    let axis = raylib.vector3(0.0, 1.0, 0.0);
    let scale = raylib.vector3(1.0, 1.0, 1.0);
    pos.draw_point(raylib.WHITE);
    pos.draw_line_to(axis, raylib.WHITE);
    pos.draw_box(
        1.0,
        1.0,
        1.0,
        raylib.WHITE,
    );
    pos.draw_box_size(scale, raylib.WHITE);
    pos.draw_sphere(1.0, raylib.WHITE);
    pos.draw_cylinder(
        1.0,
        1.0,
        2.0,
        8,
        raylib.WHITE,
    );
    pos.draw_cylinder_to(
        axis,
        1.0,
        1.0,
        8,
        raylib.WHITE,
    );
    pos.draw_capsule_to(
        axis,
        1.0,
        8,
        8,
        raylib.WHITE,
    );
    pos.draw_plane(raylib.vector2(1.0, 1.0), raylib.WHITE);
    _ = pos.sphere_overlaps(1.0, axis, 1.0);
    let model = raylib.models.load_model("missing.glb\0");
    _ = model.is_valid();
    model.draw(pos, 1.0, raylib.WHITE);
    model.draw_ex(
        pos,
        axis,
        0.0,
        scale,
        raylib.WHITE,
    );
    let bounds = model.bounding_box();
    bounds.draw(raylib.GREEN);
    _ = bounds.overlaps(bounds);
    model.unload();

    let mesh = raylib.models.gen_mesh_cube(1.0, 1.0, 1.0)..&;
    mesh.gen_tangents();
    let material = raylib.models.load_material_default()..&;
    _ = material.is_valid();
    material.unload();
    mesh.unload();
}

// Touches window functions without relying on a real interactive window.
fn use_window_api() void {
    let win = raylib.window.open(640, 480, TITLE)
        .target_fps(60)
        .title(TITLE);
    _ = win.is_open();
    _ = win.should_close();
    _ = win.is_ready();
    _ = win.fps();
    _ = win.frame_time();
    _ = win.time();
    win.close();
}

// Locks README-shaped first-window flow.
fn use_first_window_example_shape() void {
    let win = raylib.window.open(800, 450, "raylib-kern first window\0")
        .target_fps(60);
    defer win.close();

    if (win.is_open()) {
        win.frame()
            .clear(raylib.RAYWHITE)
            .text("Hello from Kern + raylib\0", 190, 200, 20, raylib.DARKGRAY)
            .fps(10, 10)
            .end();
    }
}

// Touches drawing functions so signature drift breaks compilation early.
fn use_drawing_api() void {
    let p = raylib.vector2(10.0, 20.0);
    let q = raylib.vector2(30.0, 40.0);
    let size = raylib.vector2(50.0, 60.0);
    let rec = raylib.rectangle(
        1.0,
        2.0,
        3.0,
        4.0,
    );

    raylib.drawing.frame()
        .clear(raylib.RAYWHITE)
        .pixel(1, 2, raylib.RED)
        .line(0, 0, 10, 10, raylib.BLUE)
        .line_between(p, q, raylib.GREEN)
        .circle(20, 20, 10.0, raylib.ORANGE)
        .circle_at(p, 8.0, raylib.PURPLE)
        .rect(1, 2, 3, 4, raylib.GRAY)
        .rect_rec(rec, raylib.BLACK)
        .rect_lines(1, 2, 3, 4, raylib.WHITE)
        .fps(10, 10)
        .text(TEXT, 10, 40, 20, raylib.DARKGRAY)
        .end();
    _ = size;
    p.draw_pixel(raylib.RED);
    p.draw_circle(8.0, raylib.BLUE);
    p.draw_circle_lines(8.0, raylib.BLUE);
    p.draw_circle_gradient(8.0, raylib.WHITE, raylib.BLACK);
    p.draw_line_to(q, raylib.GREEN);
    p.draw_line_bezier_to(q, 2.0, raylib.GREEN);
    p.draw_line_dashed_to(
        q,
        2,
        2,
        raylib.GREEN,
    );
    p.draw_rect(size, raylib.GRAY);
    p.draw_poly(
        6,
        8.0,
        0.0,
        raylib.BLUE,
    );
    rec.draw(raylib.BLACK);
    rec.draw_lines(1.0, raylib.WHITE);
    rec.draw_gradient(
        raylib.WHITE,
        raylib.GRAY,
        raylib.BLACK,
        raylib.RAYWHITE,
    );
    rec.draw_rounded(0.2, 8, raylib.BLUE);
    _ = rec.contains(p);
    _ = rec.overlaps(rec);
    _ = p.inside_rect(rec);
    _ = p.circle_overlaps(8.0, q, 8.0);
    _ = p.spline_linear_to(q, 0.5);
    let _ = TEXT.measure(20);
}

// Touches keyboard and mouse functions.
fn use_input_api() void {
    _ = raylib.Key.A.pressed();
    _ = raylib.Key.SPACE.down();
    _ = raylib.Key.ESCAPE.released();
    _ = raylib.Key.ENTER.up();
    _ = raylib.MouseButton.LEFT.pressed();
    _ = raylib.MouseButton.RIGHT.down();
    _ = raylib.MouseButton.MIDDLE.released();
    _ = raylib.MouseButton.LEFT.up();
    _ = raylib.input.mouse_position();
    _ = raylib.input.mouse_delta();
}

// Touches texture functions without requiring the test to load a real asset.
fn use_texture_api() void {
    let tex = raylib.textures.load_texture(TEXTURE_PATH)..&;
    let pos = raylib.vector2(0.0, 0.0);
    let src = raylib.rectangle(
        0.0,
        0.0,
        16.0,
        16.0,
    );
    tex.draw(0, 0, raylib.WHITE);
    tex.draw_at(pos, raylib.WHITE);
    tex.draw_ex(
        pos,
        0.0,
        1.0,
        raylib.WHITE,
    );
    tex.draw_rec(src, pos, raylib.WHITE);
    tex.gen_mipmaps();
    tex.unload();
}

// Locks README-shaped texture flow.
fn use_texture_example_shape() void {
    let win = raylib.window.open(800, 450, "textures\0")
        .target_fps(60);
    defer win.close();

    let logo = raylib.textures.load_texture("resources/raylib_logo.png\0")..&;
    defer logo.unload();

    if (win.is_open()) {
        let frame = win.frame().clear(raylib.RAYWHITE);
        logo.draw_at(raylib.vector2(40.0, 40.0), raylib.WHITE);
        frame.end();
    }
}

// Locks README-shaped image-to-texture flow.
fn use_image_example_shape() void {
    let image = raylib.images.load_image("resources/raylib_logo.png\0")..&;
    defer image.unload();

    image.flip_vertical();
    image.draw_text(
        "loaded from an image\0",
        8,
        8,
        18,
        raylib.BLACK,
    );

    let texture = image.to_texture();
    defer texture.unload();
}

// Locks README-shaped audio flow.
fn use_audio_example_shape() void {
    let audio = raylib.audio.open();
    defer audio.close();

    let sound = raylib.audio.load_sound("resources/click.wav\0")..&;
    defer sound.unload();

    sound.set_volume(0.8).play();

    let music = raylib.audio.load_music_stream("resources/theme.ogg\0")..&;
    defer music.unload();

    music.play();
    if (music.is_playing()) {
        music.update();
    }
}

// Touches module paths so the focused public modules remain part of the API.
fn use_module_api() void {
    let rec = raylib.rectangle(
        0.0,
        0.0,
        16.0,
        16.0,
    );
    let pos = raylib.vector2(0.0, 0.0);
    let color = raylib.WHITE.alpha(0.5);
    let image = raylib.images.gen_image_color(16, 16, color)..&;
    _ = image.is_valid();
    image.flip_vertical();
    image.draw_text(
        TEXT,
        1,
        1,
        8,
        raylib.BLACK,
    );
    let tex = image.to_texture();
    _ = tex.is_valid();
    tex.draw_rec(rec, pos, raylib.WHITE);
    _ = TEXT.measure(20);
    _ = raylib.input.mouse_position();
    _ = TEXTURE_PATH.file_exists();
    _ = TEXTURE_PATH.has_extension(".png\0");
    _ = TEXTURE_PATH.file_name();
    let paths = ".\0".directory_files();
    _ = paths.len();
    _ = paths.is_empty();
    paths.unload_directory();
    _ = ".\0".directory_files_ex("*\0", false);
    _ = ".\0".directory_file_count();
    _ = ".\0".directory_file_count_ex("*\0", false);
    _ = ".\0".prev_directory_path();
    tex.unload();
    image.unload();

    let audio = raylib.audio.open().volume(1.0);
    _ = audio.is_ready();
    _ = audio.current_volume();
    let sound = raylib.audio.load_sound("missing.wav\0")..&;
    _ = sound.is_valid();
    sound.set_volume(0.5).play();
    sound.stop();
    sound.unload();
    audio.close();
}

// Entry point for the compile-only test.
fn main() i32 {
    // Keep these calls behind an impossible branch so the test locks API shape
    // without opening a real window in CI or headless development shells.
    if (false) {
        use_window_api();
        use_first_window_example_shape();
        use_drawing_api();
        use_input_api();
        use_texture_api();
        use_texture_example_shape();
        use_image_example_shape();
        use_audio_example_shape();
        use_module_api();
        use_shader_api();
        use_text_api();
        use_model_api();
    }
    return 0;
}
