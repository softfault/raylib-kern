use base.test;
use raylib;

fn check_color_constants() void {
    let white = raylib.WHITE;
    test.eq(white.r, 255);
    test.eq(white.g, 255);
    test.eq(white.b, 255);
    test.eq(white.a, 255);
    test.eq(raylib.BLANK.a, 0);
}

fn check_constructors() void {
    let v = raylib.vector2(3.0, 4.0);
    test.eq(v.x, 3.0);
    test.eq(v.y, 4.0);

    let c = raylib.color(1, 2, 3, 4);
    test.eq(c.r, 1);
    test.eq(c.g, 2);
    test.eq(c.b, 3);
    test.eq(c.a, 4);
}

fn check_input_constants() void {
    test.eq(match (raylib.Key.A) {
        .A => 65,
        _ => 0,
    }, 65);
    test.eq(match (raylib.Key.ESCAPE) {
        .ESCAPE => 256,
        _ => 0,
    }, 256);
    test.eq(match (raylib.MouseButton.LEFT) {
        .LEFT => 1,
        _ => 0,
    }, 1);
}

fn main() i32 {
    check_color_constants();
    check_constructors();
    check_input_constants();
    return 0;
}
